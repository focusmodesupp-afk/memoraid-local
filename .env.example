# PostgreSQL
# Supabase Session Pooler (מומלץ – תומך IPv4):
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
# דוגמה: postgresql://postgres.cmkuuvbwspsmgqtlnbti:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres
API_PORT=3001
VITE_PORT=5173

# Resend - for sending invite emails (optional, leave empty to disable)
# Get API key at https://resend.com
RESEND_API_KEY=
# Optional: custom from email (default: onboarding@resend.dev)
# RESEND_FROM=MemorAId <noreply@yourdomain.com>

# App base URL (for invite links, Stripe callbacks)
APP_BASE_URL=http://localhost:5173

# Google OAuth – כניסה עם Gmail + חיבור ליומן
# מדריך מפורט: docs/GOOGLE_LOGIN_SETUP.md
#
# ב-Google Cloud → OAuth Client:
#   Authorised JavaScript origins:   http://localhost:5173  (רק דומיין, בלי /api)
#   Authorised redirect URIs:       http://localhost:5173/api/auth/google/callback
#                                   http://localhost:5173/api/integrations/google/oauth/callback
#
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# AI Providers (optional - סדר עדיפות: Claude → OpenAI → Gemini)
# Anthropic Claude - מועדף לניתוח פרויקט, תכנון פיצ'רים, שאלות
ANTHROPIC_API_KEY=
# OpenAI - Fallback כשהמפתח למעלה חסר
OPENAI_API_KEY=
# Google Gemini - Fallback שלישי (חינמי ב-Google AI Studio)
GOOGLE_GENERATIVE_AI_API_KEY=
# Perplexity - Web search context (Phase 5, optional)
PERPLEXITY_API_KEY=

# Dev Bypass – דילוג על אימות אדמין עם ?dev=1 (רק development)
# השאר ריק ב-production
DEV_SKIP_AUTH=

# N8N Workflow Automation (optional — for enhanced NEXUS research)
# Start N8N: docker compose -f docker-compose.n8n.yml up -d
# Access: http://localhost:5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_API_KEY=
N8N_TIMEOUT_MS=60000

# Dev-only: secret to access /health/* dev endpoints (create tables, reset passwords)
# Leave empty in production – endpoints will return 404
DEV_SECRET=
# Dev-only: password used by reset-all-passwords and update-admin-password
DEV_RESET_PASSWORD=

# Sensitive data encryption (idNumber, insuranceNumber) – 32 bytes hex
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Supabase/Neon: אם מתקבלת SELF_SIGNED_CERT_IN_CHAIN, הוסף:
# NODE_TLS_REJECT_UNAUTHORIZED=0
#
# Supabase – חיבור מומלץ לשרת Node.js persistent:
#   Session mode (פורט 5432): postgres://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:5432/postgres
#   Direct (פורט 5432):       postgresql://postgres:[pwd]@db.[ref].supabase.co:5432/postgres
# אם מקבלים 500 בהתחברות – נסה פורט 5432 במקום 6543 (Transaction mode לא תומך ב-prepared statements)
